#!/usr/bin/env python3
"""Generate or verify repository-scoped Claude Code, Codex, and Kimi profiles."""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import pathlib
import stat
import subprocess
import sys
import tempfile


SOURCE_ROOT = pathlib.Path(__file__).resolve().parent
MARKETPLACE = "charly-plugins"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        usage="%(prog)s <claude|codex|kimi> [--check|--dry-run] "
        "[developer|user|container FAMILY] [--project PATH]"
    )
    parser.add_argument("harness", choices=("claude", "codex", "kimi"))
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--check", action="store_true")
    mode.add_argument("--dry-run", action="store_true")
    parser.add_argument("profile", nargs="?", default="developer")
    parser.add_argument("family", nargs="?")
    parser.add_argument("--project", type=pathlib.Path)
    args = parser.parse_args()
    if args.profile not in {"developer", "user", "container"}:
        parser.error(f"unknown profile: {args.profile}")
    if args.profile == "container" and not args.family:
        parser.error("container profile requires a family")
    if args.profile != "container" and args.family:
        parser.error(f"unexpected family for {args.profile} profile")
    return args


def git_root(path: pathlib.Path) -> pathlib.Path:
    result = subprocess.run(
        ["git", "-C", str(path), "rev-parse", "--show-toplevel"],
        capture_output=True,
        text=True,
    )
    root = pathlib.Path(result.stdout.strip()) if result.returncode == 0 else path
    return root.resolve()


def managed_project_path(
    project: pathlib.Path, relative: pathlib.Path, leaf_kind: str
) -> pathlib.Path:
    """Return a write target only when every existing component stays in-project."""
    current = project
    for index, part in enumerate(relative.parts):
        current = current / part
        if current.is_symlink():
            raise SystemExit(f"refusing managed path through symlink: {current}")
        if current.exists():
            is_leaf = index == len(relative.parts) - 1
            expected_kind = leaf_kind if is_leaf else "directory"
            if expected_kind == "directory" and not current.is_dir():
                raise SystemExit(f"managed directory path has wrong type: {current}")
            if expected_kind == "file" and not current.is_file():
                raise SystemExit(f"managed file path has wrong type: {current}")
    path = project / relative
    try:
        path.parent.resolve().relative_to(project)
    except ValueError as error:
        raise SystemExit(f"refusing managed path outside project: {path}") from error
    return path


def catalog_plugin_root(project: pathlib.Path, entry: dict) -> pathlib.Path:
    source = entry.get("source")
    if not isinstance(source, str):
        raise SystemExit("plugin catalog source must be a string")
    relative = pathlib.PurePosixPath(source)
    parts = tuple(part for part in relative.parts if part != ".")
    if relative.is_absolute() or len(parts) != 1 or parts[0] in {"", ".."}:
        raise SystemExit(f"invalid plugin catalog source: {source}")
    plugins_root = (project / "plugins").resolve()
    plugin_root = (project / "plugins" / parts[0]).resolve()
    try:
        plugin_root.relative_to(plugins_root)
    except ValueError as error:
        raise SystemExit(f"plugin catalog source escapes project plugins: {source}") from error
    if plugin_root.parent != plugins_root or not plugin_root.is_dir():
        raise SystemExit(f"plugin catalog source is not a direct plugin directory: {source}")
    return plugin_root


def is_opencharly(root: pathlib.Path) -> bool:
    if not (root / "AGENTS.md").is_file():
        return False
    result = subprocess.run(
        ["git", "-C", str(root), "ls-files", "--stage", "plugins"],
        capture_output=True,
        text=True,
    )
    return result.returncode == 0 and result.stdout.startswith("160000 ")


def load_contract(project: pathlib.Path, profile: str, family: str | None):
    catalog_path = project / "plugins" / ".claude-plugin" / "marketplace.json"
    if not catalog_path.is_file():
        raise SystemExit(
            f"{project} has no repository-local Charly marketplace at "
            "plugins/.claude-plugin/marketplace.json; add the plugins repository at ./plugins"
        )
    catalog = json.loads(catalog_path.read_text())
    entries = catalog.get("plugins") if isinstance(catalog, dict) else None
    if not isinstance(entries, list) or not all(isinstance(entry, dict) for entry in entries):
        raise SystemExit(f"{catalog_path} plugins must be a list of objects")
    for entry in entries:
        catalog_plugin_root(project, entry)
    profiles = json.loads((SOURCE_ROOT / "profiles.json").read_text())
    all_plugins = [entry["name"] for entry in catalog["plugins"]]
    if profile == "container":
        if family not in profiles["container_families"]:
            raise SystemExit(f"unknown container family: {family}")
        selected = ["charly-core", f"charly-{family}"]
        label = f"container:{family}"
    else:
        selected = profiles[profile]
        label = profile
    unknown = set(selected) - set(all_plugins)
    if unknown:
        raise SystemExit(f"profile references plugins missing from the project catalog: {sorted(unknown)}")
    return catalog, all_plugins, selected, label


def validate_codex_plugins(project: pathlib.Path, catalog: dict) -> None:
    for entry in catalog["plugins"]:
        plugin_root = catalog_plugin_root(project, entry)
        manifest_path = plugin_root / ".codex-plugin" / "plugin.json"
        if not manifest_path.is_file():
            raise SystemExit(f"{plugin_root} has no .codex-plugin/plugin.json")
        manifest = json.loads(manifest_path.read_text())
        if manifest.get("name") != entry["name"]:
            raise SystemExit(
                f"{manifest_path} name does not match marketplace entry {entry['name']}"
            )
        if manifest.get("skills") != "./skills/" or not (plugin_root / "skills").is_dir():
            raise SystemExit(f"{manifest_path} does not reference the shared ./skills/ tree")
        mcp = manifest.get("mcpServers")
        if mcp is not None and (mcp != "./.mcp.json" or not (plugin_root / ".mcp.json").is_file()):
            raise SystemExit(f"{manifest_path} has an invalid MCP companion reference")


def claude_document(path: pathlib.Path, all_plugins: list[str], selected: list[str]) -> dict:
    if path.is_file():
        document = json.loads(path.read_text())
    else:
        document = {}
    enabled = document.setdefault("enabledPlugins", {})
    wanted = set(selected)
    for plugin in all_plugins:
        if plugin not in wanted:
            enabled.pop(f"{plugin}@{MARKETPLACE}", None)
    for plugin in selected:
        enabled[f"{plugin}@{MARKETPLACE}"] = True
    marketplaces = document.setdefault("extraKnownMarketplaces", {})
    marketplaces[MARKETPLACE] = {
        "source": {"source": "directory", "path": "./plugins"}
    }
    return document


def codex_document(path: pathlib.Path, catalog: dict, selected: list[str]) -> dict:
    wanted = set(selected)
    managed = {}
    for entry in catalog["plugins"]:
        source = catalog_plugin_root(path.parents[2], entry).name
        managed[entry["name"]] = {
            "name": entry["name"],
            "source": {"source": "local", "path": f"./plugins/{source}"},
            "policy": {
                "installation": (
                    "INSTALLED_BY_DEFAULT" if entry["name"] in wanted else "AVAILABLE"
                ),
                "authentication": "ON_INSTALL",
            },
            "category": entry.get("category", "OpenCharly"),
        }

    document = json.loads(path.read_text()) if path.is_file() else {}
    document.setdefault("name", MARKETPLACE)
    interface = document.setdefault("interface", {})
    interface.setdefault("displayName", "OpenCharly")
    existing = document.setdefault("plugins", [])
    if not isinstance(existing, list):
        raise SystemExit(f"{path} plugins must be a list")
    merged = []
    seen = set()
    for plugin in existing:
        name = plugin.get("name") if isinstance(plugin, dict) else None
        if name in managed:
            if name not in seen:
                merged.append(managed[name])
                seen.add(name)
        else:
            merged.append(plugin)
    for entry in catalog["plugins"]:
        name = entry["name"]
        if name not in seen:
            merged.append(managed[name])
    document["plugins"] = merged
    return document


def repo_skill_links(project: pathlib.Path, catalog: dict, selected: list[str]) -> dict[pathlib.Path, str]:
    """Return repo-native skill links without copying canonical skill content."""
    wanted = set(selected)
    links: dict[pathlib.Path, str] = {}
    skills_root = project / ".agents" / "skills"
    for entry in catalog["plugins"]:
        if entry["name"] not in wanted:
            continue
        plugin_root = catalog_plugin_root(project, entry)
        plugin_skills = plugin_root / "skills"
        for skill_file in sorted(plugin_skills.glob("*/SKILL.md")):
            skill_dir = skill_file.parent
            try:
                skill_dir.resolve().relative_to(plugin_skills.resolve())
            except ValueError as error:
                raise SystemExit(f"skill directory escapes plugin tree: {skill_dir}") from error
            link = skills_root / f"{entry['name']}--{skill_dir.name}"
            links[link] = os.path.relpath(skill_dir, skills_root)
    return links


def skill_inventory_path(skills_root: pathlib.Path) -> pathlib.Path:
    path = skills_root / ".charly-profile.json"
    if path.is_symlink():
        raise SystemExit(f"refusing symlinked skill inventory: {path}")
    if path.exists() and not path.is_file():
        raise SystemExit(f"skill inventory has wrong type: {path}")
    return path


def managed_skill_links(skills_root: pathlib.Path) -> dict[pathlib.Path, str]:
    if not skills_root.is_dir():
        return {}
    inventory_path = skill_inventory_path(skills_root)
    if inventory_path.is_file():
        inventory = json.loads(inventory_path.read_text())
        if not isinstance(inventory, dict) or inventory.get("version") != 1:
            raise SystemExit(f"{inventory_path} has an unsupported inventory version")
        recorded = inventory.get("links")
        if not isinstance(recorded, dict):
            raise SystemExit(f"{inventory_path} links must be an object")
        plugin_root = (skills_root.parents[1] / "plugins").resolve()
        validated = {}
        for name, target in recorded.items():
            if (
                not isinstance(name, str)
                or not name
                or name in {".", ".."}
                or "/" in name
                or "\\" in name
                or pathlib.Path(name).is_absolute()
                or pathlib.Path(name).name != name
            ):
                raise SystemExit(f"{inventory_path} has an invalid link name")
            if not isinstance(target, str) or not target or pathlib.Path(target).is_absolute():
                raise SystemExit(f"{inventory_path} has an invalid target for {name}")
            path = skills_root / name
            if path.parent != skills_root:
                raise SystemExit(f"{inventory_path} link escapes the skills root")
            try:
                (path.parent / target).resolve().relative_to(plugin_root)
            except ValueError as error:
                raise SystemExit(
                    f"{inventory_path} target for {name} escapes the project plugin tree"
                ) from error
            if path.is_symlink() and os.readlink(path) == target:
                validated[path] = target
        return validated

    return {}


def write_skill_inventory(skills_root: pathlib.Path, expected: dict[pathlib.Path, str]) -> None:
    inventory = {
        "version": 1,
        "links": {path.name: target for path, target in sorted(expected.items())},
    }
    atomic_write(skill_inventory_path(skills_root), serialized(inventory))


def preflight_repo_skill_links(
    expected: dict[pathlib.Path, str], actual: dict[pathlib.Path, str]
) -> None:
    for path, target in expected.items():
        if path.is_symlink():
            if os.readlink(path) != target:
                raise SystemExit(f"refusing to replace non-profile path: {path}")
        elif path.exists():
            raise SystemExit(f"refusing to replace non-profile path: {path}")
    for path, target in actual.items():
        if path not in expected and (not path.is_symlink() or os.readlink(path) != target):
            raise SystemExit(f"refusing to remove changed profile path: {path}")


def sync_repo_skill_links(
    expected: dict[pathlib.Path, str],
    actual: dict[pathlib.Path, str],
    check: bool,
    dry_run: bool,
) -> bool:
    skills_root = next(iter(expected)).parent if expected else None
    if skills_root is None:
        raise SystemExit("profile selected no skills")
    if check:
        return actual == expected and all(path.resolve().joinpath("SKILL.md").is_file() for path in expected)
    if dry_run:
        return True
    skills_root.mkdir(parents=True, exist_ok=True)
    for path in set(actual) - set(expected):
        path.unlink()
    for path, target in expected.items():
        if path.is_symlink() and os.readlink(path) == target:
            continue
        if path.exists() or path.is_symlink():
            raise SystemExit(f"refusing to replace non-profile path: {path}")
        path.symlink_to(target, target_is_directory=True)
    write_skill_inventory(skills_root, expected)
    return True


def serialized(document: dict) -> str:
    return json.dumps(document, indent=2, ensure_ascii=False) + "\n"


def kimi_snippet_path() -> pathlib.Path:
    """The committed Kimi user-config snippet shipped next to this script."""
    path = SOURCE_ROOT / "kimi-user-config.toml"
    if not path.is_file():
        raise SystemExit(f"kimi user-config snippet is missing: {path}")
    return path


def atomic_write(path: pathlib.Path, contents: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    mode = stat.S_IMODE(path.stat().st_mode) if path.exists() else 0o644
    with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False) as temporary:
        temporary.write(contents)
        temporary.flush()
        os.fsync(temporary.fileno())
        temporary_path = pathlib.Path(temporary.name)
    try:
        os.chmod(temporary_path, mode)
        os.replace(temporary_path, path)
    finally:
        temporary_path.unlink(missing_ok=True)


def main() -> int:
    args = parse_args()
    project = git_root(args.project or pathlib.Path.cwd())
    project_fd = os.open(project, os.O_RDONLY)
    fcntl.flock(project_fd, fcntl.LOCK_EX)
    if is_opencharly(project) and args.profile != "developer":
        raise SystemExit(
            "the OpenCharly repository requires the developer profile; "
            "use reduced profiles from an external consumer repository"
        )

    catalog, all_plugins, selected, label = load_contract(
        project, args.profile, args.family
    )
    if args.harness == "codex":
        validate_codex_plugins(project, catalog)
    document: dict | None = None
    path: pathlib.Path | None = None
    skill_links: dict[pathlib.Path, str] = {}
    skills_actual: dict[pathlib.Path, str] = {}
    if args.harness == "claude":
        path = managed_project_path(
            project, pathlib.Path(".claude/settings.json"), "file"
        )
        document = claude_document(path, all_plugins, selected)
    else:
        if args.harness == "codex":
            path = managed_project_path(
                project, pathlib.Path(".agents/plugins/marketplace.json"), "file"
            )
            document = codex_document(path, catalog, selected)
        else:
            # Kimi consumes the repo-native skill links directly and writes no
            # marketplace document; the user config snippet is emitted, never
            # installed by setup (it must exist to keep the profile honest).
            kimi_snippet_path()
        managed_project_path(project, pathlib.Path(".agents/skills"), "directory")
        skill_links = repo_skill_links(project, catalog, selected)
        skills_actual = managed_skill_links(next(iter(skill_links)).parent)
        # Validate the complete reconciliation plan before any project write.
        preflight_repo_skill_links(skill_links, skills_actual)
    expected = serialized(document) if document is not None else ""

    if args.check:
        skills_ok = args.harness == "claude" or sync_repo_skill_links(
            skill_links, skills_actual, True, False
        )
        document_ok = document is None or (
            path.is_file() and path.read_text() == expected
        )
        if not document_ok or not skills_ok:
            target = path if document is not None else project / ".agents" / "skills"
            print(f"{target} does not match the {label} {args.harness} profile", file=sys.stderr)
            return 1
        suffix = f", {len(skill_links)} repo-native skills" if args.harness != "claude" else ""
        print(f"{args.harness} project profile is {label} ({len(selected)} plugins{suffix})")
        return 0
    if args.dry_run:
        if args.harness == "kimi":
            print(
                f"would sync {len(skill_links)} repo-native skill links for {label} "
                f"({len(selected)} plugins) and print {kimi_snippet_path()}"
            )
        else:
            suffix = f" and {len(skill_links)} repo-native skill links" if args.harness == "codex" else ""
            print(f"would write {path}{suffix} for {label} ({len(selected)} plugins)")
        return 0

    if args.harness != "claude":
        sync_repo_skill_links(skill_links, skills_actual, False, False)
    if args.harness == "kimi":
        print(f"synced {len(skill_links)} repo-native skill links for {label} ({len(selected)} plugins)")
        print(f"merge the snippet from {kimi_snippet_path()} into ~/.kimi-code/config.toml:")
        sys.stdout.write(kimi_snippet_path().read_text())
        return 0
    atomic_write(path, expected)
    suffix = f" and {len(skill_links)} repo-native skills" if args.harness == "codex" else ""
    print(f"wrote {path}{suffix} for {label} ({len(selected)} plugins)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
